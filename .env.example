# =============================================================================
# Medical Equipment Rental System - Environment Configuration
# Copy this file to .env and modify values as needed.
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite (default, zero-config, recommended for local development)
# Format: sqlite:///./path/to/database.db
DATABASE_URL=sqlite:///./medical_rental.db

# PostgreSQL (for production or advanced development)
# Format: postgresql://user:password@host:port/dbname
# DATABASE_URL=postgresql://user:password@localhost:5432/medical_rental

# -----------------------------------------------------------------------------
# JWT Authentication Configuration
# -----------------------------------------------------------------------------
# Secret key for signing JWT tokens. CHANGE THIS IN PRODUCTION!
# Generate a secure key with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# Algorithm used for JWT signing
JWT_ALGORITHM=HS256

# Access token expiration time in minutes (default: 24 hours)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Application display name
APP_NAME=Medical Equipment Rental System

# Application environment: development | testing | production
# - development: auto-apply migrations, debug mode enabled
# - testing: used by pytest, in-memory database
# - production: no auto-migrations, debug mode disabled
APP_ENV=development

# Enable debug mode (auto-reload, detailed error pages)
APP_DEBUG=true

# -----------------------------------------------------------------------------
# Overdue Fee Configuration
# -----------------------------------------------------------------------------
# Daily overdue fee rate per device (in currency units)
OVERDUE_DAILY_RATE=50.0

# Grace period in days before overdue fees start
OVERDUE_GRACE_PERIOD_DAYS=1

# -----------------------------------------------------------------------------
# Device Lock Configuration
# -----------------------------------------------------------------------------
# Device lock timeout in minutes for reservation/import operations
DEVICE_LOCK_TIMEOUT_MINUTES=30
